// ========== HELPERS ==========
function validate(){
  if(state.currentIndex<0){toast('กรุณาเลือกหน้าการ์ตูนก่อน','error');return false;}
  if(state.isProcessing) return false;
  return true;
}

function setProcessing(val){
  state.isProcessing=val;
  const btn=document.getElementById('btn-detect');
  if(btn){
    btn.disabled=val||state.currentIndex<0;
    btn.innerHTML=val?'<div class="spinner"></div> กำลังประมวลผล...':'🔍 Auto Detect + OCR ทั้งหน้า';
  }
  const btnT=document.getElementById('btn-translate');
  if(btnT && val) btnT.disabled=true;
}

