async function runMultiDetect() {
  if(!state.pages.length) { toast('อัพโหลดรูปก่อนครับ','error'); return; }
  multiCancelled = false;
  const btn = document.getElementById('btn-mp-detect');
  const wrap = document.getElementById('mp-progress-wrap');
  const label = document.getElementById('mp-progress-label');
  const cancelBtn = document.getElementById('btn-mp-cancel');

  btn.disabled = true;
  if(wrap) wrap.style.display = 'block';
  if(cancelBtn) cancelBtn.style.display = 'block';
  if(label) label.textContent = 'กำลัง Detect...';

  for(let i = 0; i < state.pages.length; i++) {
    if(multiCancelled) break;

    // switch ไปหน้านั้น
    await switchToPageAndWait(i);
    if(label) label.textContent = `Detect หน้า ${i+1}/${state.pages.length}...`;
    updateMPStatus(i, 'none');

    try {
      const img = document.getElementById('base-img');
      if(!img || !img.naturalWidth) { updateMPStatus(i,'error'); continue; }
      const canvas = document.createElement('canvas');
      canvas.width = img.naturalWidth; canvas.height = img.naturalHeight;
      canvas.getContext('2d').drawImage(img, 0, 0);
      const imageData = canvas.toDataURL('image/jpeg',0.9).split(',')[1];

      const res = await fetch('/api/mc_detect', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({image: imageData, threshold: 0.35})
      });
      const data = await res.json();
      if(data.success && data.boxes?.length > 0) {
        clearAllBoxes();
        for(const b of data.boxes) createTextBox({x:b.x,y:b.y,w:b.w,h:b.h,text:'📖 รอ OCR...'});
        enableTranslateBtn(); enableExport();
        // Save boxes ไว้กับหน้านี้เพื่อให้กลับมาดู/แก้ไขได้
        state.pages[i].savedBoxes = state.textBoxes.map(b => ({...b}));
        state.pages[i].savedOcrResults = [...state.ocrResults];
        updateMPStatus(i, 'detected');
      } else {
        updateMPStatus(i, 'error');
      }
    } catch(e) {
      updateMPStatus(i, 'error');
    }
  }

  btn.disabled = false;
  if(cancelBtn) cancelBtn.style.display = 'none';
  if(label) label.textContent = multiCancelled ? 'ยกเลิกแล้วครับ' : 'Detect เสร็จแล้วครับ!';
  if(!multiCancelled) toast(`✅ Detect ทุกหน้าเสร็จแล้วครับ`, 'success');
}

async function runMultiTranslate() {
  if(!state.pages.length) { toast('อัพโหลดรูปก่อนครับ','error'); return; }
  multiCancelled = false;
  const btn = document.getElementById('btn-mp-translate');
  const wrap = document.getElementById('mp-progress-wrap');
  const label = document.getElementById('mp-progress-label');
  const cancelBtn = document.getElementById('btn-mp-cancel');

  btn.disabled = true;
  if(wrap) wrap.style.display = 'block';
  if(cancelBtn) cancelBtn.style.display = 'block';
  if(label) label.textContent = 'กำลัง OCR + แปล...';

  for(let i = 0; i < state.pages.length; i++) {
    if(multiCancelled) break;
    // ข้ามหน้าที่แปลแล้วหรือไม่มี box
    if(state.pages[i].mpStatus === 'translated') continue;

    await switchToPageAndWait(i);
    if(label) label.textContent = `OCR+แปล หน้า ${i+1}/${state.pages.length}...`;

    try {
      if(!state.textBoxes.length) { updateMPStatus(i,'error'); continue; }
      await runOcrAndTranslate();
      // Save boxes หลังแปลเสร็จ
      state.pages[i].savedBoxes = state.textBoxes.map(b => ({...b}));
      state.pages[i].savedOcrResults = [...state.ocrResults];
      updateMPStatus(i, 'translated');
    } catch(e) {
      updateMPStatus(i, 'error');
    }
  }

  btn.disabled = false;
  if(cancelBtn) cancelBtn.style.display = 'none';
  if(label) label.textContent = multiCancelled ? 'ยกเลิกแล้วครับ' : 'แปลเสร็จแล้วครับ!';
  if(!multiCancelled) toast(`✅ แปลทุกหน้าเสร็จแล้วครับ`, 'success');
}

function cancelMulti() {
  multiCancelled = true;
  document.getElementById('btn-mp-cancel').style.display = 'none';
}

async function switchToPageAndWait(index) {
  // Save boxes ของหน้าปัจจุบันก่อน switch
  if(state.currentIndex >= 0 && state.currentIndex !== index) {
    state.pages[state.currentIndex].savedBoxes = state.textBoxes.map(b => ({...b}));
    state.pages[state.currentIndex].savedOcrResults = [...state.ocrResults];
  }

  if(state.currentIndex === index) return;
  const thumbs = document.querySelectorAll('.page-thumb');
  if(thumbs[index]) thumbs[index].click();
  else { state.currentIndex = index; loadPage(index); }
  await new Promise(r => setTimeout(r, 500));

  // Restore boxes ของหน้าใหม่ถ้ามี saved
  const saved = state.pages[index]?.savedBoxes;
  if(saved?.length) {
    clearAllBoxes();
    state.ocrResults = state.pages[index].savedOcrResults || [];
    for(const b of saved) {
      createTextBox({...b});
      const el = document.getElementById(b.id);
      if(el) applyBoxStyle(el, b);
    }
    enableTranslateBtn(); enableExport();
  }
}

