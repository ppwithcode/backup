  saveHistory();
}

function updateCustomMaskStatus(box){
  const status = document.getElementById('custom-mask-status');
  const clearBtn = document.getElementById('btn-clear-custom-mask');
  if(!status) return;
  if(box && box.customMask && box.customMask.length > 0){
    status.textContent = `✅ Custom Mask (${box.customMask.length} จุด)`;
    status.style.color = 'var(--accent)';
    if(clearBtn) clearBtn.style.display = '';
  } else {
    status.textContent = 'ใช้ Box Rectangle (default)';
    status.style.color = 'var(--text-dim)';
    if(clearBtn) clearBtn.style.display = 'none';
  }
}

