// ========== OCR เฉพาะกรอบที่วาด ==========
// ========== OCR QUEUE — ส่ง OCR ทีละอัน ไม่ rate limit ==========
const ocrQueue = [];
let ocrRunning = false;

function queueOcr(box){
  // แสดง loading ทันที
  box.text = '⏳ รอคิว...';
  const el = document.getElementById(box.id);
  if(el) applyBoxStyle(el, box);
  ocrQueue.push(box);
  processOcrQueue();
}

async function processOcrQueue(){
  if(ocrRunning || ocrQueue.length === 0) return;
  ocrRunning = true;

  while(ocrQueue.length > 0){
    const box = ocrQueue.shift();
    // ตรวจว่า box ยังอยู่ในรายการ (อาจถูกลบไปแล้ว)
    if(!state.textBoxes.find(b => b.id === box.id)){
      continue;
    }
    await ocrSingleBox(box);
    // หน่วงเล็กน้อยระหว่าง request เพื่อไม่ให้ rate limit
    if(ocrQueue.length > 0) await new Promise(r => setTimeout(r, 300));
  }

  ocrRunning = false;
}

async function ocrSingleBox(box){
  try{
    box.text = '⏳ กำลังอ่าน...';
    const el0 = document.getElementById(box.id);
    if(el0) applyBoxStyle(el0, box);

    const img = document.getElementById('base-img');
    const canvas = document.createElement('canvas');
    canvas.width = box.w;
    canvas.height = box.h;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, box.x, box.y, box.w, box.h, 0, 0, box.w, box.h);
    const croppedDataUrl = canvas.toDataURL('image/jpeg', 0.95);
    const base64 = croppedDataUrl.split(',')[1];

    const res = await fetch('/api/ocr_crop', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({image: base64, mime_type: 'image/jpeg'})
    });
    const data = await res.json();

    if(data.success && data.text){
      box.text = data.text;
      box.korean = data.text;
      const el = document.getElementById(box.id);
      if(el) applyBoxStyle(el, box);
      const existing = state.ocrResults.find(r => r.id === box.id);
      if(existing){ existing.korean = data.text; }
      else { state.ocrResults.push({id: box.id, korean: data.text, thai: ''}); }
      enableTranslateBtn();
      if(state.selectedBox === box.id){
        document.getElementById('selected-korean').value = box.korean || '';
      }

      // แปลทันทีหลัง OCR เสร็จ (เฉพาะกรณีวาดกรอบเอง ไม่ใช่ auto detect)
      if(box._autoOcr){
        // auto detect → ไม่ auto-แปล รอกด OCR+แปลทีเดียว
        box.text = data.text;
        const el2 = document.getElementById(box.id);
        if(el2) applyBoxStyle(el2, box);
        renderBalloonList();
        toast('✅ อ่านสำเร็จ', 'success');
      } else {
        // วาดกรอบเอง → auto-แปลทันที
        try{
          const tRes = await fetch('/api/translate', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({texts: [data.text], studio_prompt: getStudioSystemPrompt()})
          });
          const tData = await tRes.json();
          if(tData.success && tData.translations?.[0]){
            const thai = tData.translations[0];
            box.text = thai;
            const ocrR = state.ocrResults.find(r => r.id === box.id);
            if(ocrR) ocrR.thai = thai;
            if(state.selectedBox === box.id){
              document.getElementById('selected-thai').value = thai;
            }
          } else {
            box.text = data.text;
          }
        } catch(te){
          box.text = data.text;
        }
        const el3 = document.getElementById(box.id);
        if(el3) applyBoxStyle(el3, box);
        renderBalloonList();
        toast('✅ อ่านและแปลสำเร็จ', 'success');
      }
    } else {
      box.text = '❌ อ่านไม่ได้';
      const el = document.getElementById(box.id);
      if(el) applyBoxStyle(el, box);
      toast('❌ อ่านไม่ได้: ' + (data.error||''), 'error');
    }
  } catch(e){
    box.text = '❌ Error';
    const el = document.getElementById(box.id);
    if(el) applyBoxStyle(el, box);
    toast('❌ OCR ล้มเหลว: '+e.message, 'error');
  }
}

