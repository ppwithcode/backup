      w:Math.floor(W*0.8),h:boxH,text:r.thai||r.korean,korean:r.korean});
  });
  setStep('box','done'); enableExport(); renderBalloonList();
  toast(`📝 วาง ${count} Box สำเร็จ`,'success');
}

function parseResults(korean,thai){
  const kLines=korean.split('---').map(s=>s.trim()).filter(Boolean);
  const tLines=thai.split('---').map(s=>s.trim()).filter(Boolean);
