function renderBoxEl(box){
  const container=document.getElementById('canvas-container');

  // ลบ bubble frame เก่าออกก่อน (ถ้ามี)
  const oldFrame = document.getElementById('bubble-frame-'+box.id);
  if(oldFrame) oldFrame.remove();

  const el=document.createElement('div');
  el.className='text-box-el'; el.id=box.id;
  el.style.left=box.x+'px'; el.style.top=box.y+'px';
  el.style.width=box.w+'px'; el.style.height=box.h+'px';

  // ถ้ามี polygon (Lasso/Pen) → ใช้ CSS clip-path แสดงรูปร่างจริงๆ
  if(box.polygon && box.polygon.length >= 3){
    const pts = box.polygon.map(p => {
      const px = ((p.x - box.x) / box.w * 100).toFixed(1) + '%';
      const py = ((p.y - box.y) / box.h * 100).toFixed(1) + '%';
      return px + ' ' + py;
    }).join(', ');
    el.style.clipPath = `polygon(${pts})`;
  }

  // Purple mask overlay
  const mask = document.createElement('div');
  mask.className = 'text-box-mask';
  mask.style.cssText = `
    position:absolute; inset:0;
    background:rgba(139,92,246,0.12);
    border-radius:inherit;
    pointer-events:none;
    z-index:0;
  `;
  el.appendChild(mask);

  applyBoxStyle(el,box);
  const rh=document.createElement('div'); rh.className='resize-handle'; el.appendChild(rh);
  ['nw','ne','sw','se'].forEach(pos => {
    const c = document.createElement('div');
    c.className = `corner ${pos}`;
    c.dataset.corner = pos;
    el.appendChild(c);
  });
  const db=document.createElement('div'); db.className='delete-btn'; db.textContent='×';
  db.onclick=e=>{e.stopPropagation();removeBox(box.id);}; el.appendChild(db);
  el.addEventListener('click',e=>{e.stopPropagation();selectBox(box.id);});
  makeDraggable(el,box); makeResizable(el,box,rh);
  container.appendChild(el);
}

function applyBoxStyle(el,box){
  const r=parseInt(box.bgColor.slice(1,3),16);
  const g=parseInt(box.bgColor.slice(3,5),16);
  const b=parseInt(box.bgColor.slice(5,7),16);
  el.style.background=`rgba(${r},${g},${b},${box.bgOpacity/100})`;
  el.style.color=box.color;
  el.style.fontFamily=`'${box.font}',sans-serif`;
  el.style.fontSize=box.size+'px';
  el.style.lineHeight = box.lineHeight ? box.lineHeight : 1.4;

  // Shape — สี่เหลี่ยม หรือ วงรี
  const shape = box.shape || 'rect';
  if(shape === 'circle'){
    el.style.borderRadius = '50%';
    el.style.borderStyle = 'dashed';
  } else {
    el.style.borderRadius = '4px';
    el.style.borderStyle = 'dashed';
  }

  // Stroke ด้วย text-shadow สี่ทิศทาง
  const sw = box.strokeWidth||0;
  const sc = box.strokeColor||'#ffffff';
  if(sw > 0){
    const s = sw;
    el.style.textShadow = `
      -${s}px -${s}px 0 ${sc},
       ${s}px -${s}px 0 ${sc},
      -${s}px  ${s}px 0 ${sc},
       ${s}px  ${s}px 0 ${sc},
      -${s}px  0    0 ${sc},
       ${s}px  0    0 ${sc},
       0    -${s}px 0 ${sc},
       0     ${s}px 0 ${sc}
    `;
  } else {
    el.style.textShadow = 'none';
  }

  // Set text — รองรับ newline (\n) จากการพิมพ์ Enter
  el.style.whiteSpace = 'pre-wrap';
  el.style.wordBreak = 'break-word';
  // ลบ text nodes เดิมออก (ไม่แตะ child elements เช่น resize handle, delete btn)
  Array.from(el.childNodes).forEach(node => {
    if(node.nodeType === Node.TEXT_NODE) el.removeChild(node);
  });
  el.insertBefore(document.createTextNode(box.text), el.firstChild);
}

