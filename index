          <button id="btn-clear-custom-mask" onclick="clearCustomMask()" style="padding:5px 8px;background:none;border:1px solid var(--border);border-radius:6px;color:var(--text-dim);font-size:11px;cursor:pointer;" title="ลบ Custom Mask">✕</button>
        </div>
      </div>
    </div>

    <!-- Slideshow Panel — ทุก Box -->
    <div id="all-boxes-panel" style="display:none;position:fixed;top:0;right:0;width:300px;height:100vh;background:var(--surface);border-left:1px solid var(--border);z-index:9998;overflow-y:auto;padding:16px;box-shadow:-4px 0 20px rgba(0,0,0,0.4);">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <span style="font-family:'Space Mono',monospace;font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim);">📋 ทุก Box</span>
        <button onclick="toggleAllBoxesPanel()" style="background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:16px;">✕</button>
      </div>
      <div id="all-boxes-list" style="display:flex;flex-direction:column;gap:8px;"></div>
    </div>

    <!-- Hidden textareas สำหรับ export (ไม่แสดง UI) -->
    <textarea id="source-text" style="display:none;"></textarea>
    <textarea id="translated-text" style="display:none;"></textarea>

    <div class="tool-section" id="balloon-section" style="display:none;">
      <div class="tool-section-title">📋 รายการ Balloon</div>
      <div class="balloon-list" id="balloon-list"></div>
    </div>

    <div class="tool-section">
      <div class="tool-section-title">💾 Export</div>
      <button class="btn-primary" id="btn-export-final" onclick="exportFinal()" disabled style="margin-bottom:5px;">🖼️ Export รูปพร้อมคำแปล</button>
      <button class="btn-primary" id="btn-export-psd" onclick="exportPSD()" disabled style="margin-bottom:5px;background:linear-gradient(135deg,#0ea5e9,#6366f1);">
        🎨 Export PSD (Photoshop)
      </button>
      <div class="export-row">
        <button class="btn-export" id="btn-export-txt" onclick="exportText()" disabled>📄 TXT</button>
        <button class="btn-export" id="btn-export-clean" onclick="exportClean()" disabled>🖼️ รูปต้นฉบับ</button>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ========== STATE ==========
const state = {
  pages:[], currentIndex:-1, isProcessing:false,
  textBoxes:[], selectedBox:null, drawMode:false,
  drawTool:'rect',
  isDrawing:false, drawStart:{x:0,y:0},
  lassoPoints:[], penPoints:[],
  ocrResults:[],
  scale:1, panX:0, panY:0,
  isPanning:false, panStart:{x:0,y:0}, panOrigin:{x:0,y:0},
  spaceDown:false,
  maskMode: false,
  // Undo/Redo history
  history:[], historyIndex:-1
};

// ========== UNDO/REDO ==========
function saveHistory(){
  // ตัด history ข้างหน้าออก (ถ้ากด undo แล้ว action ใหม่)
  state.history = state.history.slice(0, state.historyIndex + 1);
  // เก็บ snapshot ของ textBoxes (deep copy)
  state.history.push(JSON.parse(JSON.stringify(state.textBoxes)));
  state.historyIndex = state.history.length - 1;
  // จำกัดไว้แค่ 50 steps
  if(state.history.length > 50){
    state.history.shift();
    state.historyIndex--;
  }
  updateUndoRedoBtns();
  // Auto-save boxes กลับไปที่ page ปัจจุบันเสมอ
  // ทำให้ตอน switch หน้าแล้วกลับมา จะเห็น boxes ล่าสุดเสมอครับ
  if(state.currentIndex >= 0 && state.pages[state.currentIndex]) {
    state.pages[state.currentIndex].savedBoxes = JSON.parse(JSON.stringify(state.textBoxes));
    state.pages[state.currentIndex].savedOcrResults = JSON.parse(JSON.stringify(state.ocrResults));
  }
}

function undo(){
  if(state.historyIndex <= 0) return;
  state.historyIndex--;
  restoreHistory(state.history[state.historyIndex]);
  toast('↩️ Undo', 'success');
  updateUndoRedoBtns();
}

function redo(){
  if(state.historyIndex >= state.history.length - 1) return;
  state.historyIndex++;
  restoreHistory(state.history[state.historyIndex]);
  toast('↪️ Redo', 'success');
  updateUndoRedoBtns();
}

function restoreHistory(snapshot){
  // ลบ HTML elements เดิมออกทั้งหมด
  state.textBoxes.forEach(b=>{
    const el=document.getElementById(b.id); if(el) el.remove();
  });
  state.selectedBox = null;
  document.getElementById('edit-section').style.display='none';

  // สร้าง boxes ใหม่จาก snapshot
  state.textBoxes = JSON.parse(JSON.stringify(snapshot));
  state.textBoxes.forEach(box => renderBoxEl(box));

  renderBalloonList();
  if(state.textBoxes.length) enableExport();
}

function updateUndoRedoBtns(){
  const btnUndo = document.getElementById('btn-undo');
  const btnRedo = document.getElementById('btn-redo');
  if(btnUndo) btnUndo.disabled = state.historyIndex <= 0;
  if(btnRedo) btnRedo.disabled = state.historyIndex >= state.history.length - 1;
}

// ========== INIT ==========
window.onload = () => {
  initModelSelector();
  initStudio();
  const zone = document.getElementById('upload-zone');
  zone.addEventListener('dragover', e=>{e.preventDefault();zone.classList.add('drag-over');});
  zone.addEventListener('dragleave', ()=>zone.classList.remove('drag-over'));
  zone.addEventListener('drop', e=>{e.preventDefault();zone.classList.remove('drag-over');handleFiles(e.dataTransfer.files);});

  // Zoom with mouse wheel
  document.getElementById('viewport').addEventListener('wheel', onWheel, {passive:false});

  // Pan with mouse
  document.getElementById('viewport').addEventListener('mousedown', onViewportMouseDown);
  document.addEventListener('mousemove', onViewportMouseMove);
  document.addEventListener('mouseup', onViewportMouseUp);

  // Space key for pan
  document.addEventListener('keydown', e=>{
    if(e.code==='Space' && !e.target.matches('textarea,input')){e.preventDefault();state.spaceDown=true;updateCursor();}
    if(e.code==='Escape'){
      deselectAll();
      if(state.drawMode) toggleDrawMode();
      state.penPoints=[];
      state.lassoPoints=[];
      clearOverlay();
    }
    // ข้ามการทำงานถ้า focus อยู่ใน textarea/input
    const inInput = e.target.matches('textarea,input');

    // Delete/Backspace — ลบ box ที่เลือก
    if((e.code==='Delete'||e.code==='Backspace') && state.selectedBox && !inInput){
      e.preventDefault();
      removeBox(state.selectedBox);
    }

    // Tab — เลือก box ถัดไป / Shift+Tab — เลือก box ก่อนหน้า
    if(e.code==='Tab' && !inInput && state.textBoxes.length > 0){
      e.preventDefault();
      const boxes = state.textBoxes;
      // ถ้า selectedBox เป็น null (เช่นหลังลบ) ให้ใช้ lastTabIndex แทน
      const currentIdx = state.selectedBox
        ? boxes.findIndex(b => b.id === state.selectedBox)
        : (state.lastTabIndex !== undefined ? state.lastTabIndex - 1 : -1);
      let nextIdx;
      if(e.shiftKey){
        nextIdx = currentIdx <= 0 ? boxes.length - 1 : currentIdx - 1;
      } else {
        nextIdx = currentIdx >= boxes.length - 1 ? 0 : currentIdx + 1;
      }
      state.lastTabIndex = nextIdx;
      selectBox(boxes[nextIdx].id);
      const el = document.getElementById(boxes[nextIdx].id);
      if(el) el.scrollIntoView({behavior:'smooth', block:'nearest'});
    }

    if(!inInput){
      // Undo: Ctrl+Z
      if(e.ctrlKey && e.code==='KeyZ'){ e.preventDefault(); undo(); }
      // Redo: Ctrl+Y
      if(e.ctrlKey && (e.code==='KeyY' || e.code==='KeyX')){ e.preventDefault(); redo(); }
      // F1/F2/F3 — Apply font preset
      if(e.code==='F1'){ e.preventDefault(); applyFontPreset(0); }
      if(e.code==='F2'){ e.preventDefault(); applyFontPreset(1); }
      if(e.code==='F3'){ e.preventDefault(); applyFontPreset(2); }
      // M — Mark/Unmark box ที่เลือกอยู่ เพื่อลบทีหลัง
      if(e.code==='KeyM' && state.selectedBox){
        e.preventDefault();
        toggleMarkBox(state.selectedBox);
      }
      // Ctrl+D — ลบทุก box ที่ mark ไว้
      if(e.ctrlKey && e.code==='KeyD'){
        e.preventDefault();
        deleteMarkedBoxes();
      }
    }
  });
  document.addEventListener('keyup', e=>{
    if(e.code==='Space'){state.spaceDown=false;updateCursor();}
  });
  // โหลดฟอนต์จาก folder fonts/ อัตโนมัติ
  loadFontsFromFolder();
  // โหลด font presets จาก localStorage
  loadPresetsFromStorage();
};

// ========== ZOOM/PAN ==========
function applyTransform(){
  document.getElementById('transform-wrap').style.transform = `translate(${state.panX}px,${state.panY}px) scale(${state.scale})`;
  document.getElementById('zoom-label').textContent = Math.round(state.scale*100)+'%';
}

function onWheel(e){
  e.preventDefault();
  if(e.altKey){
    // Alt+Scroll = Zoom in/out
    const vp = document.getElementById('viewport');
    const rect = vp.getBoundingClientRect();
    const mouseX = e.clientX - rect.left;
    const mouseY = e.clientY - rect.top;
    const delta = e.deltaY > 0 ? -0.15 : 0.15;
    const newScale = Math.min(Math.max(state.scale + delta, 0.2), 5);
    const scaleRatio = newScale / state.scale;
    state.panX = mouseX - scaleRatio*(mouseX - state.panX);
    state.panY = mouseY - scaleRatio*(mouseY - state.panY);
    state.scale = newScale;
    applyTransform();
  } else {
    // Scroll ปกติ = เลื่อนขึ้น-ลง
    state.panY -= e.deltaY;
    applyTransform();
  }
}

function zoomBy(delta){
  const vp = document.getElementById('viewport');
  const cx = vp.offsetWidth/2, cy = vp.offsetHeight/2;
  const newScale = Math.min(Math.max(state.scale+delta,0.2),5);
  const r = newScale/state.scale;
  state.panX = cx - r*(cx-state.panX);
  state.panY = cy - r*(cy-state.panY);
  state.scale = newScale;
  applyTransform();
}

function resetZoom(){
  state.scale=1; state.panX=0; state.panY=0;
  applyTransform();
}

function fitToScreen(){
  const img = document.getElementById('base-img');
  if(!img.naturalWidth) return;
  const vp = document.getElementById('viewport');
  const scaleX = vp.offsetWidth / img.naturalWidth;
  const scaleY = vp.offsetHeight / img.naturalHeight;
  state.scale = Math.min(scaleX, scaleY) * 0.95;
  state.panX = (vp.offsetWidth - img.naturalWidth * state.scale) / 2;
  state.panY = (vp.offsetHeight - img.naturalHeight * state.scale) / 2;
  applyTransform();
}

function onViewportMouseDown(e){
  // Space ค้าง + คลิกซ้าย = Pan
  if(e.button === 0 && state.spaceDown){
    e.preventDefault();
    state.isPanning=true;
    state.panStart={x:e.clientX, y:e.clientY};
    state.panOrigin={x:state.panX, y:state.panY};
    document.getElementById('viewport').classList.add('panning');
    return;
  }
  // Middle click = Pan
  if(e.button === 1){
    e.preventDefault();
    state.isPanning=true;
    state.panStart={x:e.clientX, y:e.clientY};
    state.panOrigin={x:state.panX, y:state.panY};
    document.getElementById('viewport').classList.add('panning');
    return;
  }

  if(!state.drawMode || e.target.closest('.text-box-el')) return;
  e.preventDefault();
  const pos = getCanvasPos(e);

  if(state.drawTool === 'rect'){
    // กรอบสี่เหลี่ยม — เหมือนเดิม
    state.isDrawing=true;
    state.drawStart=pos;
    const sr = document.getElementById('selection-rect');
    sr.style.display='block';
    sr.style.left=pos.x+'px'; sr.style.top=pos.y+'px';
    sr.style.width='0'; sr.style.height='0';

  } else if(state.drawTool === 'lasso'){
    // Lasso — กด+ลาก สร้าง freehand path
    state.isDrawing=true;
    state.lassoPoints=[pos];

  } else if(state.drawTool === 'pen'){
    // Pen — คลิกวางจุด, ดับเบิ้ลคลิกปิด
    if(e.detail === 2){
      // ดับเบิ้ลคลิก — ปิด polygon
      finalizePen();
      return;
    }
    // เช็คว่าคลิกใกล้จุดเริ่มต้นหรือไม่ (ปิด polygon)
    if(state.penPoints.length >= 3){
      const first = state.penPoints[0];
      const dist = Math.hypot(pos.x-first.x, pos.y-first.y);
      if(dist < 12){
        finalizePen(); return;
      }
    }
    state.penPoints.push(pos);
    drawPenOverlay(state.penPoints);
  }
}

function onViewportMouseMove(e){
  if(state.isPanning){
    state.panX = state.panOrigin.x + (e.clientX - state.panStart.x);
    state.panY = state.panOrigin.y + (e.clientY - state.panStart.y);
    applyTransform(); return;
  }

  if(!state.isDrawing) {
    // Pen preview — แสดง preview เส้นจาก จุดสุดท้ายถึง mouse
    if(state.drawMode && state.drawTool==='pen' && state.penPoints.length > 0){
      const pos = getCanvasPos(e);
      drawPenOverlay(state.penPoints, pos);
    }
    return;
  }

  const pos = getCanvasPos(e);

  if(state.drawTool === 'rect'){
    const sr = document.getElementById('selection-rect');
    const x = Math.min(pos.x, state.drawStart.x);
    const y = Math.min(pos.y, state.drawStart.y);
    const w = Math.abs(pos.x - state.drawStart.x);
    const h = Math.abs(pos.y - state.drawStart.y);
    sr.style.left=x+'px'; sr.style.top=y+'px';
    sr.style.width=w+'px'; sr.style.height=h+'px';

  } else if(state.drawTool === 'lasso'){
    state.lassoPoints.push(pos);
    drawLassoOverlay(state.lassoPoints);
  }
}

function onViewportMouseUp(e){
  if(state.isPanning){
    state.isPanning=false;
    document.getElementById('viewport').classList.remove('panning');
    return;
  }

  if(!state.isDrawing) return;
  state.isDrawing=false;

  if(state.drawTool === 'rect'){
    document.getElementById('selection-rect').style.display='none';
    const pos = getCanvasPos(e);
    const x = Math.min(pos.x, state.drawStart.x);
    const y = Math.min(pos.y, state.drawStart.y);
    const w = Math.abs(pos.x - state.drawStart.x);
    const h = Math.abs(pos.y - state.drawStart.y);
    if(w>20 && h>15){
      createTextBox({x,y,w,h,text:'📖 รอ OCR...'});
      enableTranslateBtn();
    }

  } else if(state.drawTool === 'lasso'){
    // วาดเสร็จ — ปิด polygon อัตโนมัติ
    if(state.lassoPoints.length >= 3){
      finalizeLasso();
    } else {
      state.lassoPoints=[];
      clearOverlay();
    }
  }
  // pen ไม่ trigger ที่ mouseUp ใช้ click แทน
}

// Convert viewport mouse pos → canvas-container local pos
function getCanvasPos(e){
  const container = document.getElementById('canvas-container');
  const rect = container.getBoundingClientRect();
  return {
    x: (e.clientX - rect.left) / state.scale,
    y: (e.clientY - rect.top) / state.scale
  };
}

function updateCursor(){
  const vp = document.getElementById('viewport');
  if(state.drawMode){
    const cursors = {rect:'crosshair', lasso:'cell', pen:'crosshair'};
    vp.style.cursor = cursors[state.drawTool] || 'crosshair';
    return;
  }
  if(state.spaceDown){ vp.style.cursor='grab'; return; }
  vp.style.cursor='default';
}

// ========== FILES ==========
function handleFiles(files){
  const imgs = Array.from(files).filter(f=>f.type.startsWith('image/'));
  if(!imgs.length){toast('กรุณาเลือกไฟล์รูปภาพ','error');return;}
  imgs.forEach(file=>{
    const reader=new FileReader();
    reader.onload=e=>{
      state.pages.push({name:file.name, dataUrl:e.target.result, originalDataUrl:e.target.result});
      renderPages();
      if(state.pages.length===1) selectPage(0);
      updateBtns();
    };
    reader.readAsDataURL(file);
  });
  toast(`📂 อัพโหลด ${imgs.length} หน้าสำเร็จ`,'success');
  setStep('upload','done');
}

function renderPages(){
  const list = document.getElementById('pages-list');
  document.getElementById('page-count').textContent = state.pages.length + ' หน้า';
  const empty = document.getElementById('empty-state');
  if(!state.pages.length){
    if(empty) empty.style.display = 'flex';
    list.innerHTML = ''; return;
  }
  if(empty) empty.style.display = 'none';
  list.innerHTML = '';

  const STATUS_ICON = { detected:'🔍', translated:'✅', error:'❌' };

  state.pages.forEach((p, i) => {
    const isActive = i === state.currentIndex;
    const statusIcon = STATUS_ICON[p.mpStatus] || '';

    const div = document.createElement('div');
    div.className = 'page-thumb' + (isActive ? ' active' : '');
    div.style.marginBottom = '6px';
    div.onclick = () => selectPage(i);

    // Image wrapper
    const imgWrap = document.createElement('div');
    imgWrap.style.position = 'relative';

    const img = document.createElement('img');
    img.src = p.dataUrl;
    img.style.cssText = 'width:100%;display:block;max-height:110px;object-fit:cover;';
    imgWrap.appendChild(img);

    // Active badge
    if(isActive){
      const badge = document.createElement('div');
      badge.textContent = '● กำลังดูอยู่';
      badge.style.cssText = 'position:absolute;top:5px;left:5px;background:var(--accent);color:white;font-size:9px;padding:2px 6px;border-radius:4px;font-weight:800;';
      imgWrap.appendChild(badge);
    }

    // Status badge
    if(statusIcon){
      const sb = document.createElement('div');
      sb.textContent = statusIcon;
      sb.style.cssText = 'position:absolute;bottom:4px;right:4px;background:rgba(0,0,0,0.65);border-radius:4px;font-size:12px;padding:1px 4px;';
      imgWrap.appendChild(sb);
    }

    div.appendChild(imgWrap);

    // Info bar
    const info = document.createElement('div');
    info.className = 'page-thumb-info';
    const num = document.createElement('span');
    num.className = 'page-num';
    num.textContent = 'หน้า ' + (i+1);
    if(isActive){ num.style.color = 'var(--accent)'; num.style.fontWeight = '700'; }
    const delBtn = document.createElement('button');
    delBtn.className = 'btn-delete';
    delBtn.textContent = '🗑️';
    delBtn.onclick = (e) => deletePage(i, e);
    info.appendChild(num);
    info.appendChild(delBtn);
    div.appendChild(info);

    list.appendChild(div);
  });
}
function deletePage(i,e){
  e.stopPropagation();
  state.pages.splice(i,1);
  if(state.currentIndex>=state.pages.length) state.currentIndex=state.pages.length-1;
  renderPages();
  if(state.pages.length) selectPage(state.currentIndex);
  else{ document.getElementById('canvas-container').style.display='none'; document.getElementById('canvas-placeholder').style.display='block'; }
  updateBtns();
}

// ========== DRAW MODE ==========
function setDrawTool(tool){
  state.drawTool = tool;
  // อัพเดตปุ่ม active
  ['rect','lasso','pen'].forEach(t => {
    const btn = document.getElementById(`btn-tool-${t}`);
    if(!btn) return;
    if(t === tool){
      btn.style.border = '2px solid var(--accent)';
      btn.style.color = 'var(--accent)';
    } else {
      btn.style.border = '';
      btn.style.color = '';
    }
  });
  // เปิด draw mode อัตโนมัติถ้ายังไม่ได้เปิด
  if(!state.drawMode) toggleDrawMode();
  updateCursor();
}

function toggleDrawMode(){
  state.drawMode=!state.drawMode;
  const btn=document.getElementById('btn-draw-mode');
  const indicator=document.getElementById('mode-indicator');
  if(state.drawMode){
    btn.classList.add('active');
    const toolName = state.drawTool==='lasso'?'Lasso':state.drawTool==='pen'?'Pen':'กรอบ';
    btn.textContent=`✏️ ${toolName} — กำลังวาด`;
    if(indicator){ indicator.textContent=`✏️ ${toolName}`; indicator.classList.add('draw'); }
    deselectAll();
    clearOverlay();
  } else {
    btn.classList.remove('active'); btn.textContent='✏️ เปิดโหมดวาด';
    if(indicator){ indicator.textContent='เลือก'; indicator.classList.remove('draw'); }
    clearOverlay();
  }
  updateCursor();
}

// ========== OVERLAY CANVAS (สำหรับ Lasso + Pen) ==========
function getOverlayCtx(){
  const oc = document.getElementById('overlay-canvas');
  return oc ? oc.getContext('2d') : null;
}

// maskOverlays: เก็บ polygon ที่ apply แล้ว เพื่อวาดซ้ำเมื่อ redraw
const maskOverlays = {}; // { boxId: [{x,y}] }

function drawAllMaskOverlays(){
  const ctx = getOverlayCtx(); if(!ctx) return;
  const oc = document.getElementById('overlay-canvas');
  // clear แล้ววาด overlays ทั้งหมดใหม่
  ctx.clearRect(0, 0, oc.width, oc.height);
  for(const [boxId, pts] of Object.entries(maskOverlays)){
    if(!pts || pts.length < 3) continue;
    ctx.beginPath();
    ctx.moveTo(pts[0].x, pts[0].y);
    pts.forEach(p => ctx.lineTo(p.x, p.y));
    ctx.closePath();
    // filled สีม่วง opacity จางๆ
    ctx.fillStyle = 'rgba(139, 92, 246, 0.25)';
    ctx.fill();
    // เส้นขอบสีม่วง
    ctx.strokeStyle = 'rgba(139, 92, 246, 0.8)';
    ctx.lineWidth = 2;
    ctx.setLineDash([5, 3]);
    ctx.stroke();
    ctx.setLineDash([]);
  }
}

function addMaskOverlay(boxId, pts){
  maskOverlays[boxId] = pts;
  drawAllMaskOverlays();
}

function removeMaskOverlay(boxId){
  delete maskOverlays[boxId];
  drawAllMaskOverlays();
}

function clearOverlay(){
  const ctx = getOverlayCtx(); if(!ctx) return;
  const oc = document.getElementById('overlay-canvas');
  ctx.clearRect(0, 0, oc.width, oc.height);
  // วาด mask overlays ถาวรกลับมา
  drawAllMaskOverlays();
}

function drawLassoOverlay(points, closing=false){
  const ctx = getOverlayCtx(); if(!ctx || points.length < 1) return;
  const oc = document.getElementById('overlay-canvas');
  ctx.clearRect(0, 0, oc.width, oc.height);
  ctx.beginPath();
  ctx.moveTo(points[0].x, points[0].y);
  points.forEach(p => ctx.lineTo(p.x, p.y));
  if(closing) ctx.closePath();
  ctx.strokeStyle = '#ff6b35';
  ctx.lineWidth = 2;
  ctx.setLineDash([5, 3]);
  ctx.stroke();
  // วงกลมที่จุดเริ่มต้น
  ctx.beginPath();
  ctx.arc(points[0].x, points[0].y, 5, 0, Math.PI*2);
  ctx.fillStyle = 'rgba(255,107,53,0.5)';
  ctx.fill();
  ctx.setLineDash([]);
}

function drawPenOverlay(points, mousePos=null){
  const ctx = getOverlayCtx(); if(!ctx) return;
  const oc = document.getElementById('overlay-canvas');
  ctx.clearRect(0, 0, oc.width, oc.height);
  if(points.length < 1) return;

  // วาดเส้นระหว่างจุด
  ctx.beginPath();
  ctx.moveTo(points[0].x, points[0].y);
  points.forEach(p => ctx.lineTo(p.x, p.y));
  if(mousePos) ctx.lineTo(mousePos.x, mousePos.y);
  ctx.strokeStyle = '#ff6b35';
  ctx.lineWidth = 2;
  ctx.setLineDash([5, 3]);
  ctx.stroke();
  ctx.setLineDash([]);

  // วาดจุด
  points.forEach((p, i) => {
    ctx.beginPath();
    ctx.arc(p.x, p.y, i===0 ? 6 : 4, 0, Math.PI*2);
    ctx.fillStyle = i===0 ? 'rgba(255,107,53,0.8)' : 'rgba(255,107,53,0.5)';
    ctx.fill();
    ctx.strokeStyle = '#ff6b35';
    ctx.lineWidth = 1.5;
    ctx.stroke();
  });
}

function getBoundingBoxFromPoints(points){
  const xs = points.map(p=>p.x), ys = points.map(p=>p.y);
  const x = Math.min(...xs), y = Math.min(...ys);
  const w = Math.max(...xs) - x;
  const h = Math.max(...ys) - y;
  return {x, y, w, h};
}

