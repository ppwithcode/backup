          color:white;font-size:11px;cursor:pointer;
        ">+ เพิ่ม</button>
      </div>
      <div id="glossary-list" style="display:flex;flex-direction:column;gap:6px;">
        <!-- rows จะถูกสร้างโดย JS -->
      </div>
    </div>

    <!-- Footer actions -->
    <div style="display:flex;gap:8px;padding-top:4px;border-top:1px solid var(--border);">
      <button onclick="clearStudio()" style="
        flex:1;padding:8px;border-radius:8px;
        background:none;border:1px solid var(--border);
        color:var(--text-dim);font-size:12px;cursor:pointer;
      ">🗑️ ล้างทั้งหมด</button>
      <button onclick="closeStudio()" style="
        flex:2;padding:8px;border-radius:8px;
        background:var(--accent);border:none;
        color:white;font-size:12px;font-weight:700;cursor:pointer;
      ">✅ บันทึกและปิด</button>
    </div>

  </div>
</div>
<!-- ==================== END STUDIO ==================== -->

</body>
</html>
