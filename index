async function runTranslate(){
  if(!validate()) return;

  // รวบรวม box ทุกอันที่มีข้อความเกาหลี
  const boxesWithKorean = state.textBoxes.filter(b => b.korean && b.korean.length > 0 && !b.korean.startsWith('⏳') && !b.korean.startsWith('❌'));

  if(!boxesWithKorean.length){
    toast('กรุณาวาดกรอบและรอให้ OCR เสร็จก่อนครับ','error');
    return;
  }

  setProcessing(true); setStep('translate','active');
  try{
    const koreanTexts = boxesWithKorean.map(b => b.korean);
    toast('🌐 กำลังแปล...','success');
    const translations = await apiTranslate(koreanTexts);

    // แทนที่ข้อความในแต่ละ Box
    boxesWithKorean.forEach((box, i) => {
      if(i < translations.length){
        box.text = translations[i];
        const el = document.getElementById(box.id);
        if(el) applyBoxStyle(el, box);
        // อัพเดต ocrResults
        const r = state.ocrResults.find(r => r.id === box.id);
        if(r) r.thai = translations[i];
      }
    });
    // re-render all boxes เพื่อให้แน่ใจ
    state.textBoxes.forEach(box => {
      const el = document.getElementById(box.id);
      if(el) applyBoxStyle(el, box);
    });

    document.getElementById('translated-text').value = translations.join('\n---\n');
    document.getElementById('source-text').value = koreanTexts.join('\n---\n');
    setStep('translate','done');
    renderBalloonList();
    toast(`🌐 แปล ${translations.length} กรอบสำเร็จ!`,'success');
  }catch(e){
    setStep('translate','idle');
    toast('❌ แปลล้มเหลว: '+e.message,'error');
  }finally{setProcessing(false);}
}

function placeBoxesAuto(){
