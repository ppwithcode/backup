// Build system prompt สำหรับส่งไป Gemini
function getStudioSystemPrompt() {
  const prompt = (document.getElementById('studio-prompt')?.value || '').trim();
  const glossaryLines = studioGlossary
    .filter(r => r.kr && r.th)
    .map(r => `${r.kr} → ${r.th}`)
    .join('\n');

  let system = '';
  if (prompt) system += `[Context]: ${prompt}\n`;
  if (glossaryLines) system += `[Glossary - ใช้คำแปลเหล่านี้ให้คงที่]:\n${glossaryLines}\n`;
  return system.trim();
}

