// ========== DRAG / RESIZE (ใน natural image coords) ==========
function makeDraggable(el,box){
  el.addEventListener('mousedown',e=>{
    if(e.target.classList.contains('resize-handle')||e.target.classList.contains('delete-btn')) return;
    e.preventDefault(); e.stopPropagation();
    const startX=e.clientX,startY=e.clientY;
    const startL=box.x,startT=box.y;
    const onMove=e=>{
      const dx=(e.clientX-startX)/state.scale;
      const dy=(e.clientY-startY)/state.scale;
      box.x=startL+dx; box.y=startT+dy;
      el.style.left=box.x+'px'; el.style.top=box.y+'px';
    };
    const onUp=()=>{document.removeEventListener('mousemove',onMove);document.removeEventListener('mouseup',onUp);};
    document.addEventListener('mousemove',onMove);
    document.addEventListener('mouseup',onUp);
  });
}

function makeResizable(el, box, handle){
  // SE handle (เดิม)
  handle.addEventListener('mousedown', e=>{
    e.preventDefault(); e.stopPropagation();
    const startX=e.clientX, startY=e.clientY, startW=box.w, startH=box.h;
    const onMove=e=>{
      box.w=Math.max(50, startW+(e.clientX-startX)/state.scale);
      box.h=Math.max(24, startH+(e.clientY-startY)/state.scale);
      el.style.width=box.w+'px'; el.style.height=box.h+'px';
    };
    const onUp=()=>{
      document.removeEventListener('mousemove',onMove);
      document.removeEventListener('mouseup',onUp);
      saveHistory();
    };
    document.addEventListener('mousemove',onMove);
    document.addEventListener('mouseup',onUp);
  });

  // Corner handles ทั้ง 4 มุม
  el.querySelectorAll('.corner').forEach(corner=>{
    corner.addEventListener('mousedown', e=>{
      e.preventDefault(); e.stopPropagation();
      const pos = corner.dataset.corner;
      const startX=e.clientX, startY=e.clientY;
      const startW=box.w, startH=box.h, startBX=box.x, startBY=box.y;

      const onMove=e=>{
        const dx = (e.clientX-startX)/state.scale;
        const dy = (e.clientY-startY)/state.scale;
        if(pos==='se'){
          box.w=Math.max(50, startW+dx);
          box.h=Math.max(24, startH+dy);
        } else if(pos==='sw'){
          box.x=startBX+dx; box.w=Math.max(50, startW-dx);
          box.h=Math.max(24, startH+dy);
        } else if(pos==='ne'){
          box.w=Math.max(50, startW+dx);
          box.y=startBY+dy; box.h=Math.max(24, startH-dy);
        } else if(pos==='nw'){
          box.x=startBX+dx; box.w=Math.max(50, startW-dx);
          box.y=startBY+dy; box.h=Math.max(24, startH-dy);
        }
        el.style.left=box.x+'px'; el.style.top=box.y+'px';
        el.style.width=box.w+'px'; el.style.height=box.h+'px';
      };
      const onUp=()=>{
        document.removeEventListener('mousemove',onMove);
        document.removeEventListener('mouseup',onUp);
        saveHistory();
      };
      document.addEventListener('mousemove',onMove);
      document.addEventListener('mouseup',onUp);
    });
  });
}

