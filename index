<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hexqine Translator ✦</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;600;700;900&family=Sarabun:wght@400;600;700&family=Prompt:wght@400;600;700&family=Kanit:wght@400;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#0d0d0d;--surface:#161616;--surface2:#1f1f1f;
    --border:#2a2a2a;--accent:#ff6b35;--accent2:#ffd23f;
    --text:#f0f0f0;--text-dim:#888;--success:#4ade80;
    --error:#f87171;--radius:12px;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{background:var(--bg);color:var(--text);font-family:'Noto Sans Thai',sans-serif;min-height:100vh;overflow:hidden;}

  header{display:flex;align-items:center;justify-content:space-between;padding:12px 24px;border-bottom:1px solid var(--border);background:var(--surface);position:sticky;top:0;z-index:100;height:56px;}
  .logo{display:flex;align-items:center;gap:10px;}
  .logo-icon{width:32px;height:32px;background:linear-gradient(135deg,#6366f1,#a855f7);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;box-shadow:0 0 16px rgba(99,102,241,.5);}
  .logo-text{font-family:'Space Mono',monospace;font-size:14px;font-weight:700;letter-spacing:0.5px;}
  .logo-text span{background:linear-gradient(135deg,#6366f1,#a855f7);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
  .header-right{display:flex;align-items:center;gap:10px;}
  .server-badge{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--success);}
  .dot-green{width:7px;height:7px;border-radius:50%;background:var(--success);box-shadow:0 0 6px rgba(74,222,128,.6);}
  .phase-badge{font-family:'Space Mono',monospace;font-size:10px;background:var(--surface2);border:1px solid var(--border);padding:3px 8px;border-radius:100px;color:var(--text-dim);}
  .mode-indicator{font-family:'Space Mono',monospace;font-size:10px;padding:3px 8px;border-radius:100px;background:var(--surface2);border:1px solid var(--border);color:var(--text-dim);}
  .mode-indicator.draw{border-color:var(--accent);color:var(--accent);background:rgba(255,107,53,.1);}

  .main{display:grid;grid-template-columns:240px 1fr 310px;height:calc(100vh - 56px);}

  /* LEFT */
  .panel{border-right:1px solid var(--border);overflow-y:auto;background:var(--surface);}
  .panel-header{padding:10px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--surface);z-index:10;}
  .panel-title{font-family:'Space Mono',monospace;font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim);}
  .upload-zone{margin:10px;border:2px dashed var(--border);border-radius:var(--radius);padding:18px 12px;text-align:center;cursor:pointer;transition:all .25s;position:relative;}
  .upload-zone:hover,.upload-zone.drag-over{border-color:var(--accent);background:rgba(255,107,53,.05);}
  .upload-zone input{position:absolute;inset:0;opacity:0;cursor:pointer;}
  .upload-icon{font-size:22px;margin-bottom:5px;}
  .upload-text{font-size:11px;color:var(--text-dim);line-height:1.5;}
  .upload-text strong{color:var(--accent);}
  .pages-list{padding:0 10px 10px;display:flex;flex-direction:column;gap:6px;}
  /* ========== MULTI-PAGE PANEL (floating) ========== */
  .multi-page-list{
    display:flex;flex-direction:column;gap:4px;
    max-height:300px;overflow-y:auto;
  }
  .mp-page-row{
    display:flex;align-items:center;gap:8px;
    padding:6px 8px;border-radius:8px;
    cursor:pointer;transition:background .15s;font-size:11px;
  }
  .mp-page-row:hover{ background:var(--surface2); }
  .mp-page-row.active{ background:rgba(99,102,241,0.15);border:1px solid rgba(99,102,241,0.3); }
  .mp-page-thumb{
    width:32px;height:44px;object-fit:cover;
    border-radius:4px;flex-shrink:0;background:var(--surface2);
  }
  .mp-page-info{ flex:1;min-width:0; }
  .mp-page-name{
    font-weight:600;color:var(--text);
    white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
    font-size:10px;margin-bottom:2px;
  }
  .mp-status-badge{
    display:inline-flex;align-items:center;gap:3px;
    font-size:9px;padding:1px 5px;border-radius:10px;font-weight:600;
  }
  .mp-status-badge.none{ background:rgba(255,255,255,0.06);color:var(--text-dim); }
  .mp-status-badge.detected{ background:rgba(14,165,233,0.15);color:#0ea5e9; }
  .mp-status-badge.translated{ background:rgba(16,185,129,0.15);color:#10b981; }
  .mp-status-badge.error{ background:rgba(239,68,68,0.15);color:#ef4444; }
  .page-thumb:hover{border-color:var(--border);}
  .page-thumb.active{
    border-color:var(--accent);
    box-shadow:0 0 0 2px var(--accent),0 4px 12px rgba(99,102,241,0.4);
  }
  .page-thumb img{width:100%;display:block;max-height:110px;object-fit:cover;}
  .page-thumb-info{padding:5px 8px;display:flex;justify-content:space-between;align-items:center;}
  .page-num{font-family:'Space Mono',monospace;font-size:10px;color:var(--text-dim);}
  .btn-delete{background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:12px;padding:2px 4px;border-radius:4px;transition:all .15s;}
  .btn-delete:hover{color:var(--error);background:rgba(248,113,113,.1);}
  .empty-state{padding:14px 10px;text-align:center;color:var(--text-dim);font-size:11px;line-height:1.6;}

  /* CANVAS AREA */
  .canvas-area{background:#0a0a0a;position:relative;overflow:hidden;}
  .canvas-placeholder{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;color:var(--text-dim);}
  .canvas-placeholder .big-icon{font-size:48px;opacity:.2;margin-bottom:12px;}
  .canvas-placeholder p{font-size:12px;opacity:.4;line-height:1.6;}

  /* Zoom controls */
  .zoom-controls{position:absolute;bottom:16px;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:6px;background:rgba(22,22,22,.9);border:1px solid var(--border);border-radius:100px;padding:6px 12px;z-index:50;backdrop-filter:blur(8px);}
  .zoom-btn{background:none;border:none;color:var(--text);cursor:pointer;font-size:16px;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:all .2s;}
  .zoom-btn:hover{background:var(--surface2);color:var(--accent);}
  .zoom-label{font-family:'Space Mono',monospace;font-size:11px;color:var(--text-dim);min-width:44px;text-align:center;}
  .zoom-hint{position:absolute;top:12px;left:50%;transform:translateX(-50%);font-size:10px;color:var(--text-dim);background:rgba(22,22,22,.8);padding:4px 10px;border-radius:100px;border:1px solid var(--border);white-space:nowrap;pointer-events:none;opacity:.7;}

  /* Viewport (scrollable/pannable container) */
  #viewport{position:absolute;inset:0;overflow:hidden;cursor:grab;}
  #viewport.panning{cursor:grabbing;}
  #viewport.draw-mode{cursor:crosshair;}

  /* The transform wrapper */
  #transform-wrap{position:absolute;transform-origin:0 0;will-change:transform;}

  /* Image + boxes */
  #canvas-container{position:relative;display:none;}
  #base-img{display:block;user-select:none;pointer-events:none;}
  #overlay-canvas{position:absolute;top:0;left:0;pointer-events:none;z-index:5;}
  #selection-rect{position:absolute;border:2px dashed var(--accent);background:rgba(255,107,53,.08);pointer-events:none;display:none;border-radius:2px;}

  /* Text Boxes */
  .text-box-el{position:absolute;border:2px dashed rgba(255,107,53,.6);background:rgba(255,255,255,.92);border-radius:4px;cursor:move;min-width:50px;min-height:24px;display:flex;align-items:center;justify-content:center;padding:3px 5px;text-align:center;line-height:1.3;word-break:break-word;box-shadow:0 2px 8px rgba(0,0,0,.2);transition:all .15s;user-select:none;}
  .text-box-el.selected{
    border:2px solid #f97316;
    border-style:solid;
    box-shadow:0 0 0 3px rgba(249,115,22,0.5), 0 0 16px rgba(249,115,22,0.4), 0 2px 8px rgba(0,0,0,.3);
    background:rgba(255,237,213,0.95);
    z-index:100;
  }
  .text-box-el .resize-handle{position:absolute;bottom:-5px;right:-5px;width:10px;height:10px;background:var(--accent);border-radius:2px;cursor:se-resize;display:none;}
  .text-box-el.selected .resize-handle{display:block;}
  /* Corner handles — แสดงเฉพาะตอน selected */
  .text-box-el .corner{position:absolute;width:8px;height:8px;background:var(--accent);border-radius:2px;display:none;z-index:10;}
  .text-box-el.selected .corner{display:block;}
  .text-box-el .corner.nw{top:-4px;left:-4px;cursor:nw-resize;}
  .text-box-el .corner.ne{top:-4px;right:-4px;cursor:ne-resize;}
  .text-box-el .corner.sw{bottom:-4px;left:-4px;cursor:sw-resize;}
  .text-box-el .corner.se{bottom:-4px;right:-4px;cursor:se-resize;}
  .text-box-el.marked{
    border:2px solid #ef4444 !important;
    box-shadow:0 0 0 3px rgba(239,68,68,0.5), 0 0 16px rgba(239,68,68,0.4) !important;
    background:rgba(254,202,202,0.95) !important;
  }
  .text-box-el.marked::after{
    content:'🗑️';
    position:absolute;top:-10px;left:50%;transform:translateX(-50%);
    font-size:14px;pointer-events:none;
  }width:16px;height:16px;background:var(--error);border-radius:50%;display:none;align-items:center;justify-content:center;font-size:10px;color:white;cursor:pointer;line-height:1;}
  .text-box-el.selected .delete-btn{display:flex;}
  /* bubble outer frame */
  [id^="bubble-frame-"]{pointer-events:none;z-index:3;box-sizing:border-box;}

  /* TOOLS */
  .tools-panel{border-right:none;border-left:1px solid var(--border);overflow-y:auto;}
  .tool-section{padding:10px 14px;border-bottom:1px solid var(--border);}
  .tool-section-title{font-family:'Space Mono',monospace;font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim);margin-bottom:8px;}

  .btn-primary{width:100%;padding:9px;background:var(--accent);border:none;border-radius:var(--radius);color:white;font-family:'Noto Sans Thai',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:6px;margin-bottom:6px;}
  .btn-primary:hover:not(:disabled){background:#ff8555;transform:translateY(-1px);box-shadow:0 4px 16px rgba(255,107,53,.3);}
  .btn-primary:disabled{opacity:.4;cursor:not-allowed;transform:none;}
  .btn-secondary{width:100%;padding:7px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);font-family:'Noto Sans Thai',sans-serif;font-size:12px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:6px;margin-bottom:6px;}
  .btn-secondary:hover:not(:disabled){border-color:var(--accent);color:var(--accent);}
  .btn-secondary:disabled{opacity:.4;cursor:not-allowed;}
  .btn-row{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-bottom:6px;}
  .btn-half{padding:7px 5px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Noto Sans Thai',sans-serif;font-size:11px;cursor:pointer;transition:all .2s;text-align:center;}
  .btn-half:hover:not(:disabled){border-color:var(--accent);color:var(--accent);}
  .btn-half.active{border-color:var(--accent);background:rgba(255,107,53,.1);color:var(--accent);}

  .text-label{font-size:11px;color:var(--text-dim);margin-bottom:4px;display:flex;align-items:center;gap:5px;}
  .lang-tag{font-family:'Space Mono',monospace;font-size:9px;padding:1px 5px;border-radius:100px;background:var(--surface2);border:1px solid var(--border);}
  .text-box-input{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:7px 9px;color:var(--text);font-family:'Noto Sans Thai',sans-serif;font-size:12px;line-height:1.6;resize:vertical;min-height:70px;outline:none;transition:border .2s;}
  .text-box-input:focus{border-color:var(--accent);}
  .text-box-input::placeholder{color:#444;}

  .steps{display:flex;flex-direction:column;gap:4px;margin-bottom:8px;}
  .step{display:flex;align-items:center;gap:7px;padding:5px 9px;border-radius:8px;background:var(--surface2);font-size:11px;transition:all .3s;border:1px solid transparent;}
  .step.active{background:rgba(255,107,53,.1);border-color:rgba(255,107,53,.2);}
  .step.done{background:rgba(74,222,128,.07);border-color:rgba(74,222,128,.2);}
  .step-icon{font-size:11px;width:15px;text-align:center;}
  .step-name{flex:1;color:var(--text-dim);}
  .step.active .step-name,.step.done .step-name{color:var(--text);}

  .control-row{display:flex;align-items:center;gap:7px;margin-bottom:7px;}
  .control-label{font-size:11px;color:var(--text-dim);white-space:nowrap;min-width:48px;}
  select.ctrl{flex:1;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:4px 7px;color:var(--text);font-family:'Noto Sans Thai',sans-serif;font-size:11px;outline:none;cursor:pointer;}
  select.ctrl:focus{border-color:var(--accent);}
  input[type=number].ctrl{width:55px;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:4px 7px;color:var(--text);font-size:11px;outline:none;text-align:center;}
  input[type=number].ctrl:focus{border-color:var(--accent);}
  input[type=color].ctrl{width:32px;height:26px;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:2px;cursor:pointer;}

  .balloon-list{display:flex;flex-direction:column;gap:4px;max-height:140px;overflow-y:auto;}
  .balloon-item{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:6px 9px;font-size:11px;cursor:pointer;transition:all .2s;}
  .balloon-item:hover{border-color:var(--accent);}
  .balloon-item .kr{color:var(--text-dim);margin-bottom:2px;font-size:10px;}
  .balloon-item .th{color:var(--accent2);line-height:1.4;}

  .export-row{display:grid;grid-template-columns:1fr 1fr;gap:5px;}
  .btn-export{padding:7px 5px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Noto Sans Thai',sans-serif;font-size:11px;cursor:pointer;transition:all .2s;text-align:center;}
  .btn-export:hover:not(:disabled){border-color:var(--accent2);color:var(--accent2);}
  .btn-export:disabled{opacity:.3;cursor:not-allowed;}

  .spinner{width:13px;height:13px;border:2px solid rgba(255,255,255,.3);border-top-color:white;border-radius:50%;animation:spin .6s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}
  .toast{position:fixed;bottom:16px;right:16px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:9px 13px;font-size:12px;z-index:9999;transform:translateY(80px);opacity:0;transition:all .3s cubic-bezier(.34,1.56,.64,1);max-width:270px;}
  .toast.show{transform:translateY(0);opacity:1;}
  .toast.success{border-color:rgba(74,222,128,.4);}
  .toast.error{border-color:rgba(248,113,113,.4);}
  ::-webkit-scrollbar{width:3px;}
  ::-webkit-scrollbar-track{background:transparent;}
  ::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
</style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-icon">✦</div>
    <div class="logo-text">Hexqine <span>Translator</span></div>
  </div>
  <div class="header-right">
    <div class="server-badge"><div class="dot-green"></div><span>API Key ปลอดภัย 🔒</span></div>
    <!-- Translation Studio Button -->
    <button onclick="toggleStudio()" id="btn-studio" title="Translation Studio (Ctrl+Shift+T)" style="
      display:flex;align-items:center;gap:5px;
      background:var(--surface2);border:1px solid var(--border);
      border-radius:8px;padding:4px 10px;cursor:pointer;
      font-size:11px;color:var(--text);transition:all .2s;
      white-space:nowrap;
    ">
      <span>📜</span><span>Studio</span>
    </button>
    <div style="position:relative;display:inline-block;">
      <button id="btn-model-selector" onclick="toggleModelDropdown()" style="
        display:flex;align-items:center;gap:5px;
        background:var(--surface2);border:1px solid var(--border);
        border-radius:8px;padding:4px 10px;cursor:pointer;
        font-size:11px;color:var(--text);transition:all .2s;
        white-space:nowrap;
      " title="เลือก Gemini Model">
        <span style="font-size:13px;">✦</span>
        <span id="model-badge-text">gemini-2.5-flash</span>
        <span style="font-size:9px;opacity:0.6;">▼</span>
      </button>
      <!-- Dropdown -->
      <div id="model-dropdown" style="
        display:none;position:absolute;top:calc(100% + 6px);right:0;
        background:var(--surface2);border:1px solid var(--border);
        border-radius:10px;padding:6px;min-width:200px;
        box-shadow:0 8px 24px rgba(0,0,0,0.3);z-index:9999;
      ">
        <div style="font-size:10px;color:var(--text-dim);padding:4px 8px 6px;border-bottom:1px solid var(--border);margin-bottom:4px;">
          เลือก Gemini Model
        </div>
        <button onclick="selectModel('gemini-2.5-flash')" class="model-opt" id="mopt-gemini-2.5-flash" style="
          width:100%;text-align:left;padding:7px 10px;border:none;border-radius:7px;
          background:var(--accent);color:white;cursor:pointer;font-size:12px;
          margin-bottom:3px;display:flex;align-items:center;gap:8px;
        ">
          <span>⚡</span>
          <div>
            <div style="font-weight:700;">gemini-2.5-flash</div>
            <div style="font-size:10px;opacity:0.8;">แม่น · เสถียร · แนะนำ</div>
          </div>
        </button>
        <button onclick="selectModel('gemini-2.5-flash-lite')" class="model-opt" id="mopt-gemini-2.5-flash-lite" style="
          width:100%;text-align:left;padding:7px 10px;border:none;border-radius:7px;
          background:transparent;color:var(--text);cursor:pointer;font-size:12px;
          margin-bottom:3px;display:flex;align-items:center;gap:8px;
        ">
          <span>🚀</span>
          <div>
            <div style="font-weight:700;">gemini-2.5-flash-lite</div>
            <div style="font-size:10px;opacity:0.6;">เร็วสุด · ถูกกว่า 3x · ลอง!</div>
          </div>
        </button>
        <button onclick="selectModel('gemini-2.0-flash')" class="model-opt" id="mopt-gemini-2.0-flash" style="
          width:100%;text-align:left;padding:7px 10px;border:none;border-radius:7px;
          background:transparent;color:var(--text-dim);cursor:pointer;font-size:12px;
          display:flex;align-items:center;gap:8px;opacity:0.6;
        ">
          <span>⚠️</span>
          <div>
            <div style="font-weight:700;">gemini-2.0-flash</div>
            <div style="font-size:10px;">ปิดบริการ 1 มิ.ย. 2026</div>
          </div>
        </button>
      </div>
    </div>
    <div class="mode-indicator" id="mode-indicator">เลือก</div>
    <!-- Settings Gear Button -->
    <button onclick="toggleSettingsPopup()" id="btn-settings" title="ตั้งค่า" style="
      background:var(--surface2);border:1px solid var(--border);border-radius:8px;
      width:32px;height:32px;cursor:pointer;display:flex;align-items:center;
      justify-content:center;font-size:16px;transition:all .2s;color:var(--text);
    ">⚙️</button>
  </div>
</header>

<!-- Settings Popup -->
<div id="settings-popup" style="
  display:none;position:fixed;top:64px;right:16px;width:320px;
  background:var(--surface);border:1px solid var(--border);border-radius:12px;
  box-shadow:0 8px 32px rgba(0,0,0,0.5);z-index:9999;overflow:hidden;
">
  <!-- Header -->
  <div style="padding:14px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;">
    <span style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim);">⚙️ ตั้งค่า</span>
    <button onclick="toggleSettingsPopup()" style="background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:16px;line-height:1;">✕</button>
  </div>

  <!-- Settings Content -->
  <div style="padding:16px;display:flex;flex-direction:column;gap:16px;">

    <!-- Font Default -->
    <div>
      <div style="font-size:11px;color:var(--text-dim);margin-bottom:8px;font-family:'Space Mono',monospace;text-transform:uppercase;letter-spacing:1px;">🔠 ค่าเริ่มต้นฟอนต์</div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:11px;color:var(--text-dim);min-width:56px;">ฟอนต์</span>
          <select id="setting-font" style="flex:1;background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:4px 8px;color:var(--text);font-size:12px;">
            <option value="Noto Sans Thai">Noto Sans Thai</option>
            <option value="Sarabun">Sarabun</option>
            <option value="Prompt">Prompt</option>
            <option value="Kanit">Kanit</option>
          </select>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
