let selectedModes = new Set(JSON.parse(localStorage.getItem('studio_modes') || '[]'));
let studioGlossary = [];

function initStudio() {
  const saved = localStorage.getItem('studio_prompt');
  if (saved) document.getElementById('studio-prompt').value = saved;
  const savedGlossary = localStorage.getItem('studio_glossary');
  if (savedGlossary) {
    studioGlossary = JSON.parse(savedGlossary);
    renderGlossary();
  }
  const savedModes = localStorage.getItem('studio_modes');
  if (savedModes) {
    selectedModes = new Set(JSON.parse(savedModes));
  }
  renderModeButtons();
  updateModeIndicator();
}

function toggleStudio() {
  const panel = document.getElementById('studio-panel');
  const overlay = document.getElementById('studio-overlay');
  const isOpen = panel.style.display === 'flex';
  panel.style.display = isOpen ? 'none' : 'flex';
  overlay.style.display = isOpen ? 'none' : 'block';
  const btn = document.getElementById('btn-studio');
  btn.style.background = isOpen ? 'var(--surface2)' : 'var(--accent)';
  btn.style.color = isOpen ? 'var(--text)' : 'white';
  btn.style.border = isOpen ? '1px solid var(--border)' : '1px solid var(--accent)';
}

function closeStudio() {
  document.getElementById('studio-panel').style.display = 'none';
  document.getElementById('studio-overlay').style.display = 'none';
  const btn = document.getElementById('btn-studio');
  btn.style.background = 'var(--surface2)';
  btn.style.color = 'var(--text)';
  btn.style.border = '1px solid var(--border)';
  saveStudio();
}

function saveStudio() {
  localStorage.setItem('studio_prompt', document.getElementById('studio-prompt').value);
  localStorage.setItem('studio_glossary', JSON.stringify(studioGlossary));
  localStorage.setItem('studio_modes', JSON.stringify([...selectedModes]));
}

function clearStudio() {
  document.getElementById('studio-prompt').value = '';
  studioGlossary = [];
  selectedModes = new Set();
  renderGlossary();
  renderModeButtons();
  updateModeIndicator();
  localStorage.removeItem('studio_prompt');
  localStorage.removeItem('studio_glossary');
  localStorage.removeItem('studio_modes');
  toast('\uD83D\uDDD1\uFE0F ล้าง Studio แล้วครับ', 'success');
}

function applyStudioMode(key) {
  if (key === 'custom') {
    // Custom — toggle ได้ ใช้ร่วมกับ mode อื่นใน combo ได้
    if (selectedModes.has('custom')) {
      selectedModes.delete('custom');
      toast('✏️ Custom ปิดแล้วครับ', 'success');
    } else {
      selectedModes.add('custom');
      const promptEl = document.getElementById('studio-prompt');
      if (!promptEl.value.trim()) {
        promptEl.placeholder = 'พิมพ์ context เพิ่มเติมของคุณเองได้เลยครับ...';
      }
      setTimeout(() => document.getElementById('studio-prompt').focus(), 100);
      toast('✏️ Custom เปิดแล้ว — พิมพ์ context เพิ่มเติมได้เลยครับ', 'success');
    }
  } else {
    // mode อื่น — toggle ปกติ ไม่กระทบ Custom
    if (selectedModes.has(key)) {
      selectedModes.delete(key);
      toast(STUDIO_PRESETS[key].label + ' ปิดแล้วครับ', 'success');
    } else {
      selectedModes.add(key);
      const labels = [...selectedModes]
        .filter(k => STUDIO_PRESETS[k])
        .map(k => STUDIO_PRESETS[k].label)
        .join(' + ');
      toast('✨ Combo: ' + labels, 'success');
    }
    // อัพเดต prompt เฉพาะส่วน mode (ไม่แตะ custom text)
    updatePromptFromModes();
  }
  saveStudio();
  renderModeButtons();
  updateModeIndicator();
}

function updatePromptFromModes() {
  // อัพเดตเฉพาะ modes section — ถ้ามี Custom ก็เก็บ text ที่พิมพ์ไว้ไว้ท้าย
  const modes = [...selectedModes].filter(k => k !== 'custom' && STUDIO_PRESETS[k]);
  const promptEl = document.getElementById('studio-prompt');

  if (modes.length === 0 && !selectedModes.has('custom')) {
    promptEl.value = '';
    return;
  }

  // รวม mode prompts
  const modeText = modes.map(k => STUDIO_PRESETS[k].prompt).join('\n');

  if (selectedModes.has('custom')) {
    // ถ้า Custom เปิดอยู่ → เก็บ text เดิมไว้ แค่ prepend mode prompts
    const existingCustom = promptEl.value;
    // ตัด mode prompts เก่าออกถ้ามี แล้วเอาแค่ส่วนที่ user พิมพ์เอง
    promptEl.value = modeText ? modeText + '\n\n[เพิ่มเติม]:\n' + (existingCustom.includes('[เพิ่มเติม]:') ? existingCustom.split('[เพิ่มเติม]:')[1].trim() : existingCustom) : existingCustom;
  } else {
    promptEl.value = modeText;
  }
}

function renderModeButtons() {
  document.querySelectorAll('.preset-btn').forEach(btn => {
    const key = btn.dataset.preset;
    const isActive = selectedModes.has(key);
    btn.style.background = isActive ? 'var(--accent)' : 'var(--surface2)';
    btn.style.color = isActive ? 'white' : 'var(--text)';
    btn.style.borderColor = isActive ? 'var(--accent)' : 'var(--border)';
    btn.style.boxShadow = isActive ? '0 2px 8px rgba(99,102,241,0.4)' : 'none';
  });
}

function updateModeIndicator() {
  const el = document.getElementById('studio-mode-indicator');
  if (!el) return;
  const modes = [...selectedModes].filter(k => STUDIO_PRESETS[k]);
  if (modes.length === 0) { el.style.display = 'none'; return; }
  const labels = modes.map(k => STUDIO_PRESETS[k].label).join(' + ');
  el.textContent = 'โหมด: ' + labels;
  el.style.display = 'block';
}

