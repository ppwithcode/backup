function findBoxByOverlap(polygon){
  // หา box ที่ polygon ทับมากที่สุด (IoU)
  const xs = polygon.map(p=>p.x), ys = polygon.map(p=>p.y);
  const px1=Math.min(...xs), py1=Math.min(...ys);
  const px2=Math.max(...xs), py2=Math.max(...ys);
  const polyArea = (px2-px1)*(py2-py1);

  let bestBox=null, bestScore=0;
  for(const box of state.textBoxes){
    const bx2=box.x+box.w, by2=box.y+box.h;
    const ix1=Math.max(px1,box.x), iy1=Math.max(py1,box.y);
    const ix2=Math.min(px2,bx2), iy2=Math.min(py2,by2);
    const inter=Math.max(0,ix2-ix1)*Math.max(0,iy2-iy1);
    if(inter===0) continue;
    const boxArea=box.w*box.h;
    const union=polyArea+boxArea-inter;
    const iou=inter/union;
    // containment: polygon อยู่ใน box มากแค่ไหน
    const containment=inter/polyArea;
    const score=Math.max(iou, containment);
    if(score>bestScore){ bestScore=score; bestBox=box; }
  }
  return bestScore > 0.2 ? bestBox : null;
}

function applyMaskToBox(polygon){
  const box = findBoxByOverlap(polygon);
  if(!box){
    toast('⚠️ ไม่พบ Box ที่ทับกัน ลองวาดให้ทับ Box มากขึ้นครับ', 'error');
    return;
  }
  box.customMask = polygon.map(p=>({x:p.x, y:p.y}));

  // วาด purple overlay ถาวร
  addMaskOverlay(box.id, box.customMask);

  // อัพเดต status ถ้า box นี้ selected อยู่
  if(state.selectedBox === box.id) updateCustomMaskStatus(box);

  toast(`✅ บันทึก Custom Mask ให้ Box แล้วครับ (${polygon.length} จุด)`, 'success');
  saveHistory();
}

