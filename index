// โหลดฟอนต์จาก folder fonts/ ตอน startup
async function loadFontsFromFolder(){
  try{
    const res = await fetch('/api/list_fonts');
    const data = await res.json();
    if(!data.fonts || !data.fonts.length) return;
    for(const filename of data.fonts){
      const fontName = filename.replace(/\.[^.]+$/, '');
      if(customFonts.find(f => f.name === fontName)) continue;
      try{
        const fontFace = new FontFace(fontName, `url('/fonts/${encodeURIComponent(filename)}')`);
        const loaded = await fontFace.load();
        document.fonts.add(loaded);
        customFonts.push({name: fontName, filename, enabled: true});
        addFontToDropdowns(fontName);
        console.log(`[Font] Folder loaded: ${fontName}`);
      } catch(e){ console.warn(`[Font] Skip ${filename}:`, e); }
    }
    if(customFonts.length > 0)
      toast(`✅ โหลดฟอนต์จาก folder ${customFonts.length} ไฟล์ครับ`, 'success');
  } catch(e){ console.warn('[Font] Folder load failed:', e); }
}

async function loadCustomFonts(files){
  let loaded = 0;
  for(const file of files){
    const fontName = file.name.replace(/\.[^.]+$/, '');
    if(customFonts.find(f => f.name === fontName)) continue;
    try{
      const buffer = await file.arrayBuffer();
      const fontFace = new FontFace(fontName, buffer);
      const loadedFace = await fontFace.load();
      document.fonts.add(loadedFace);
      await document.fonts.ready;
      customFonts.push({name: fontName, filename: file.name, enabled: true});
      addFontToDropdowns(fontName);
      loaded++;
      console.log(`[Font] Loaded: ${fontName}`);
    } catch(e){
      console.error(`[Font] Failed: ${fontName}`, e);
      toast(`❌ โหลดฟอนต์ ${fontName} ไม่ได้ครับ`, 'error');
    }
  }
  renderCustomFontList();
  if(loaded > 0) toast(`✅ โหลดฟอนต์สำเร็จ ${loaded} ไฟล์ครับ`, 'success');
}

function toggleCustomFont(index){
  const f = customFonts[index];
  if(!f) return;
  f.enabled = !f.enabled;
  ['font-family', 'setting-font'].forEach(id => {
    const sel = document.getElementById(id);
    if(!sel) return;
    if(f.enabled){
      if(!Array.from(sel.options).find(o => o.value === f.name))
        sel.appendChild(new Option(f.name, f.name));
    } else {
      const opt = Array.from(sel.options).find(o => o.value === f.name);
      if(opt) opt.remove();
    }
  });
  renderCustomFontList();
}

function removeCustomFont(index){
  const f = customFonts[index];
  if(!f) return;
  ['font-family', 'setting-font'].forEach(id => {
    const sel = document.getElementById(id);
    if(!sel) return;
    const opt = Array.from(sel.options).find(o => o.value === f.name);
    if(opt) opt.remove();
  });
  customFonts.splice(index, 1);
  renderCustomFontList();
}

function renderCustomFontList(){
  const list = document.getElementById('custom-font-list');
  if(!list) return;
  if(!customFonts.length){
    list.innerHTML = '<div style="font-size:11px;color:var(--text-dim);text-align:center;padding:8px;">ยังไม่มีฟอนต์ที่โหลดครับ</div>';
    return;
  }
  list.innerHTML = customFonts.map((f, i) => `
    <div style="display:flex;align-items:center;gap:8px;padding:6px 8px;background:var(--surface2);border-radius:6px;border:1px solid var(--border);">
      <input type="checkbox" ${f.enabled?'checked':''} onchange="toggleCustomFont(${i})"
        style="width:14px;height:14px;cursor:pointer;accent-color:var(--accent);">
      <span style="flex:1;font-size:14px;font-family:'${f.name}',sans-serif;color:var(--text);">${f.name}</span>
      <span style="font-size:11px;color:var(--text-dim);font-family:'${f.name}',sans-serif;">ตัวอย่าง Aa</span>
      <button onclick="removeCustomFont(${i})" style="background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:12px;">🗑️</button>
    </div>
  `).join('');
}

