function switchToPageMP(index) {
  // คลิก thumbnail ใน multi panel → switch หน้า
  const thumbs = document.querySelectorAll('.page-thumb');
  if(thumbs[index]) thumbs[index].click();
  else { state.currentIndex = index; loadPage(index); }
  renderMultiPageList();
}

function updateMPStatus(index, status) {
  if(state.pages[index]) state.pages[index].mpStatus = status;
  renderMultiPageList();
  // อัพเดต progress bar
  const done  = state.pages.filter(p => p.mpStatus === 'translated' || p.mpStatus === 'detected').length;
  const total = state.pages.length;
  const pct   = total > 0 ? (done / total * 100) : 0;
  const bar   = document.getElementById('mp-progress-bar');
  const count = document.getElementById('mp-progress-count');
  if(bar)   bar.style.width = pct + '%';
  if(count) count.textContent = `${done}/${total}`;
}

async function runMultiInpaint() {
  if(!state.pages.length) { toast('อัพโหลดรูปก่อนครับ','error'); return; }
  multiCancelled = false;
  const btn = document.getElementById('btn-mp-inpaint');
  const wrap = document.getElementById('mp-progress-wrap');
  const label = document.getElementById('mp-progress-label');
  const cancelBtn = document.getElementById('btn-mp-cancel');

  btn.disabled = true;
  if(wrap) wrap.style.display = 'block';
  if(cancelBtn) cancelBtn.style.display = 'block';

  let doneCount = 0;
  for(let i = 0; i < state.pages.length; i++) {
    if(multiCancelled) break;
    // ข้ามหน้าที่ไม่มี boxes
    const savedBoxes = state.pages[i]?.savedBoxes;
    if(!savedBoxes?.length) continue;

    await switchToPageAndWait(i);
    if(label) label.textContent = `Inpaint หน้า ${i+1}/${state.pages.length}...`;

    try {
      // รอ inpaint เสร็จโดยใช้ runInpaint จาก sidebar ขวา
      await runInpaint('anime');
      // Save inpainted image กลับไปที่ page
      const img = document.getElementById('base-img');
      state.pages[i].dataUrl = img.src;
      doneCount++;
      // อัพเดต progress
      const pct = state.pages.length > 0 ? (doneCount / state.pages.length * 100) : 0;
      const bar = document.getElementById('mp-progress-bar');
      const count = document.getElementById('mp-progress-count');
      if(bar) bar.style.width = pct + '%';
      if(count) count.textContent = `${doneCount}/${state.pages.length}`;
    } catch(e) {
      console.error(`Inpaint page ${i} error:`, e);
    }
  }

  btn.disabled = false;
  if(cancelBtn) cancelBtn.style.display = 'none';
  if(label) label.textContent = multiCancelled ? 'ยกเลิกแล้วครับ' : `Inpaint เสร็จแล้วครับ! (${doneCount} หน้า)`;
  if(!multiCancelled) toast(`✅ Inpaint ทุกหน้าเสร็จแล้วครับ (${doneCount} หน้า)`, 'success');
}

