// ========== INPAINT ==========
async function runInpaint(mode){
  if(!validate()) return;

  // inpaint ทุก box ที่มีอยู่ — ไม่จำกัดเฉพาะ box ที่มี korean
  const boxesWithKorean = state.textBoxes.filter(b => b.w > 0 && b.h > 0);
  if(!boxesWithKorean.length){
    toast('กรุณาวาดกรอบก่อนครับ','error'); return;
  }

  const img = document.getElementById('base-img');
  const canvas = document.createElement('canvas');
  canvas.width = img.naturalWidth;
  canvas.height = img.naturalHeight;
  const ctx = canvas.getContext('2d');
  ctx.drawImage(img, 0, 0);
  const imageData = canvas.toDataURL('image/jpeg', 0.95).split(',')[1];
  const fillColor = document.getElementById('inpaint-color').value;

  const btnIds = {'anime':'btn-inpaint-anime','lama':'btn-inpaint-lama','auto':'btn-inpaint-auto','color':'btn-inpaint-color'};
  const btn = document.getElementById(btnIds[mode]);
  const origHTML = btn ? btn.innerHTML : '';
  if(btn){ btn.innerHTML = '<div class="spinner"></div>'; btn.disabled = true; }

  const modeLabel = mode==='anime' ? '🎌 Anime/Manga AI' : mode==='lama' ? '🤖 LaMa AI' : mode==='auto' ? '✨ Auto สี' : '🎨 สีที่เลือก';

  // เริ่มจับเวลา
  const startTime = Date.now();

  // แสดง timer popup แบบ live
  showTimerPopup(modeLabel);

  try{
    const boxes = boxesWithKorean.map(b => ({
      x:b.x, y:b.y, w:b.w, h:b.h,
      shape: b.shape || 'rect',
      // ใช้ customMask ถ้ามี (user วาดเอง) → fallback polygon → fallback null (rectangle)
      polygon: b.customMask || b.polygon || null
    }));
    const res = await fetch('/api/inpaint', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ image: imageData, mime_type: 'image/jpeg', boxes, mode, color: fillColor })
    });
    const data = await res.json();
    if(!data.success) throw new Error(data.error);

    const elapsed = ((Date.now() - startTime) / 1000).toFixed(2);
    const newDataUrl = `data:${data.mime_type};base64,${data.image}`;
    document.getElementById('base-img').src = newDataUrl;
    if(state.currentIndex >= 0) state.pages[state.currentIndex].dataUrl = newDataUrl;

    // ลบ mask overlays ของ boxes ที่ inpaint แล้ว
    boxesWithKorean.forEach(b => removeMaskOverlay(b.id));

    // แสดง popup สรุปเวลา
    showResultPopup(modeLabel, boxes.length, elapsed);

  } catch(e){
    hideTimerPopup();
    toast('❌ Inpaint ล้มเหลว: '+e.message, 'error');
  } finally {
    if(btn){ btn.innerHTML = origHTML; btn.disabled = false; }
  }
}

