// ========== EXPORT ==========
async function exportPSD(){
  if(!validate()) return;
  const btn = document.getElementById('btn-export-psd');
  const origHTML = btn.innerHTML;
  btn.innerHTML = '<div class="spinner"></div> กำลังสร้าง PSD...';
  btn.disabled = true;
  toast('🎨 กำลังสร้างไฟล์ PSD...', 'success');

  try{
    const img = document.getElementById('base-img');
    // รูปปัจจุบัน (อาจผ่าน inpaint แล้ว)
    const canvasCurrent = document.createElement('canvas');
    canvasCurrent.width = img.naturalWidth;
    canvasCurrent.height = img.naturalHeight;
    canvasCurrent.getContext('2d').drawImage(img, 0, 0);
    const inpaintedB64 = canvasCurrent.toDataURL('image/png').split(',')[1];

    // รูปต้นฉบับ (เก็บไว้ใน state.pages)
    const origDataUrl = state.pages[state.currentIndex]?.originalDataUrl || state.pages[state.currentIndex]?.dataUrl;
    const origB64 = origDataUrl.split(',')[1];

    // Text boxes data — ส่งคำแปลไทย + ข้อมูลครบถ้วน
    const imgEl = document.getElementById('base-img');
    const dispW = imgEl.getBoundingClientRect().width;
    const dispH = imgEl.getBoundingClientRect().height;
    const natW  = imgEl.naturalWidth;
    const natH  = imgEl.naturalHeight;
    const imgScale = natW / dispW;

    const textBoxesData = state.textBoxes.map(box => {
      const ocrResult = state.ocrResults.find(r => r.id === box.id);
      // Priority: box.text → ocrResult.thai → ''
      const thaiText = box.text || ocrResult?.thai || '';

      return {
        // x/y/w/h เป็น natural image pixels อยู่แล้ว (canvas coordinates)
        x: Math.round(box.x),
        y: Math.round(box.y),
        w: Math.round(box.w),
        h: Math.round(box.h),
        text: thaiText,
        // font size: user ตั้งตรงๆ ไม่ต้อง scale — ส่งตรงๆ ให้ Photoshop
        size: box.size || 14,
        font: box.font || 'Arial',
        color: box.color || '#000000',
        bgColor: box.bgColor || '#ffffff',
        bgOpacity: box.bgOpacity || 0,
        // strokeWidth: CSS px บนจอ → natural px (ต้อง × imgScale)
        // strokeWidth: ส่งค่า CSS px ตรงๆ ไม่ต้อง × imgScale
        strokeWidth: box.strokeWidth || 0,
        strokeColor: box.strokeColor || '#ffffff',
        lineHeight: box.lineHeight || 1.4,
        imgScale: parseFloat(imgScale.toFixed(4))
      };
    });

    const res = await fetch('/api/export_psd', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        original: origB64,
        inpainted: inpaintedB64,
        text_boxes: textBoxesData,
        page_name: state.pages[state.currentIndex]?.name || `page_${state.currentIndex+1}`
      })
    });
    const data = await res.json();
    if(!data.success) throw new Error(data.error);

    // Download PSD
    const mimeType = data.format === 'zip' ? 'application/zip' : 'application/octet-stream';
    const a = document.createElement('a');
    a.href = `data:${mimeType};base64,${data.psd}`;
    a.download = data.filename || `comics_page_${state.currentIndex+1}.psd`;
    a.click();

    if(data.format === 'zip'){
      toast(`🎨 Export สำเร็จ! ได้ ZIP ที่มี ${data.message||'layers แยกกัน'} ครับ`, 'success');
    } else {
      toast('🎨 Export PSD สำเร็จครับ!', 'success');
    }

  } catch(e){
    toast('❌ Export PSD ล้มเหลว: '+e.message, 'error');
  } finally {
    btn.innerHTML = origHTML;
    btn.disabled = false;
  }
}

function exportFinal(){
  const img=document.getElementById('base-img');
  const canvas=document.createElement('canvas');
  canvas.width=img.naturalWidth; canvas.height=img.naturalHeight;
  const ctx=canvas.getContext('2d');

  // ซ่อน HTML Text Box elements ทั้งหมดก่อน
  const boxEls = document.querySelectorAll('.text-box-el');
  boxEls.forEach(el => el.style.visibility = 'hidden');

  // วาดรูปพื้นหลัง (base-img ล้วนๆ ไม่มี HTML elements)
  ctx.drawImage(img, 0, 0);

  // วาด text boxes ลงบน canvas โดยตรง (ไม่มีกรอบ HTML)
  state.textBoxes.forEach(box=>{
    const r=parseInt(box.bgColor.slice(1,3),16);
    const g=parseInt(box.bgColor.slice(3,5),16);
    const b=parseInt(box.bgColor.slice(5,7),16);

    // วาดพื้นหลัง box
    ctx.fillStyle=`rgba(${r},${g},${b},${box.bgOpacity/100})`;
    ctx.fillRect(box.x, box.y, box.w, box.h);

    // ตั้งค่าฟอนต์
    ctx.font=`${box.size}px '${box.font}',sans-serif`;
    ctx.textAlign='center';
    ctx.textBaseline='middle';

    // Word wrap — รองรับ newline (\n) จากการพิมพ์ Enter
    const paragraphs = box.text.split('\n');
    const lines = [];
    const maxW = box.w - box.size*2;

    paragraphs.forEach(para => {
      if(para === ''){
        lines.push(''); // บรรทัดว่าง
        return;
      }
      let line = '';
      for(let ch of para){
        const test = line + ch;
        if(ctx.measureText(test).width > maxW && line){
          lines.push(line); line = ch;
        } else {
          line = test;
        }
      }
      if(line) lines.push(line);
    });

    // Line height
    const lh = box.lineHeight || 1.4;
    const lineH = box.size * lh;
    const totalH = lines.length * lineH;

    lines.forEach((l,i)=>{
      const tx = box.x + box.w/2;
      const ty = box.y + box.h/2 - totalH/2 + i*lineH + lineH/2;

      // วาด Stroke ก่อน (ถ้ามี)
      const sw = box.strokeWidth || 0;
      if(sw > 0){
        ctx.lineWidth = sw * 2;
        ctx.strokeStyle = box.strokeColor || '#ffffff';
        ctx.lineJoin = 'round';
        ctx.strokeText(l, tx, ty);
      }

      // วาดข้อความ
      ctx.fillStyle = box.color;
      ctx.fillText(l, tx, ty);
    });
  });

  // Download
  const a=document.createElement('a');
  a.download=`translated_page_${state.currentIndex+1}.png`;
  a.href=canvas.toDataURL('image/png');
  a.click();

  // แสดง HTML Text Box elements กลับมา
  boxEls.forEach(el => el.style.visibility = 'visible');

  toast('💾 Export รูปสำเร็จครับ!','success');
}

